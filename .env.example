# =============================================================================
# StayBF — Environment Variable Template
# =============================================================================
# Copy this file to .env.staging or .env.production and fill in real values.
# NEVER commit .env.staging or .env.production to version control.
#
# Variable naming rules:
#   VITE_*   — public, bundled into the browser build (no secrets here)
#   all else — server-only, never reach the browser
# =============================================================================


# -----------------------------------------------------------------------------
# Supabase — Public (browser + server)
# Source: Dashboard → Settings → API
# -----------------------------------------------------------------------------

# Full project URL, e.g. https://abcdefghijkl.supabase.co
VITE_SUPABASE_URL=

# Anon/public key — safe to expose in the browser. RLS is the access gate.
VITE_SUPABASE_ANON_KEY=

# CDN base URL for public Storage buckets (property-images, room-images, avatars).
# Staging:    same as VITE_SUPABASE_URL
# Production: https://media.staybf.com (CNAME to <ref>.supabase.co) once DNS is live;
#             until then, same as VITE_SUPABASE_URL
VITE_MEDIA_BASE_URL=


# -----------------------------------------------------------------------------
# Supabase — Server-only secrets
# Source: Dashboard → Settings → API
# -----------------------------------------------------------------------------

# Mirror of VITE_SUPABASE_URL — used by server functions and scripts that
# cannot access import.meta.env.
SUPABASE_URL=

# Mirror of VITE_SUPABASE_ANON_KEY — used by the per-request server client
# to issue RLS-scoped queries on behalf of the authenticated user.
SUPABASE_ANON_KEY=

# Secret service_role key — bypasses RLS. Used ONLY by supabaseAdmin in
# src/lib/supabase/admin.ts and deployment scripts. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# JWT secret — used by scripts/validate-config.ts to verify length.
# Source: Dashboard → Settings → Auth → JWT Settings
SUPABASE_JWT_SECRET=

# Direct Postgres connection string — used by migration scripts and CI.
# Format: postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres
# Use SUPABASE_DB_POOLER_URL for runtime server queries (PgBouncer).
SUPABASE_DB_URL=

# PgBouncer transaction-mode connection string — used by server functions
# at runtime. Lower latency than the direct connection under concurrent load.
# Format: postgresql://postgres.<ref>:<password>@aws-0-eu-west-1.pooler.supabase.com:6543/postgres
SUPABASE_DB_POOLER_URL=

# Supabase project ref (the short ID, e.g. abcdefghijkl).
# Used by scripts/create-buckets.sh and supabase CLI commands.
SUPABASE_PROJECT_REF=

# Personal Access Token for the Supabase CLI (supabase.com → Account → Access Tokens).
# Used by deployment scripts that call supabase CLI commands against the remote project.
# Do NOT use the service_role key here — this is a different credential.
SUPABASE_ACCESS_TOKEN=


# -----------------------------------------------------------------------------
# Application encryption
# Used for libsodium sealed-box encryption of payout_account and
# document_number_enc columns (migrations 0003 and 0008).
# Generate with: node -e "const s = require('libsodium-wrappers'); s.ready.then(() => { const kp = s.crypto_box_keypair(); console.log('PUBLIC:', Buffer.from(kp.publicKey).toString('base64')); console.log('PRIVATE:', Buffer.from(kp.privateKey).toString('base64')); })"
# -----------------------------------------------------------------------------

# Public key (base64) — used for ENCRYPTION. Safe to load on the server.
LIBSODIUM_SEALED_BOX_PUBLIC_KEY=

# Private key (base64) — used for DECRYPTION only. Guard this carefully.
LIBSODIUM_SEALED_BOX_PRIVATE_KEY=


# -----------------------------------------------------------------------------
# CinetPay — payment provider
# Source: CinetPay merchant dashboard
# -----------------------------------------------------------------------------

CINETPAY_API_KEY=
CINETPAY_SITE_ID=

# HMAC-SHA256 webhook validation secret (set in CinetPay → Webhooks settings)
CINETPAY_WEBHOOK_SECRET=


# -----------------------------------------------------------------------------
# Virus scanning — for private Storage bucket uploads
# (message-attachments, ticket-attachments, kyc-documents, verification-documents)
# MVP: VirusTotal Free API. Production target: dedicated ClamAV instance.
# -----------------------------------------------------------------------------

ANTIVIRUS_API_URL=
ANTIVIRUS_API_KEY=
